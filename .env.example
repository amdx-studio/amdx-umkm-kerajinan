# ============================================================
#  UMKM Kerajinan — Environment Variables
#  Salin file ini menjadi .env dan isi nilainya
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key-here

# --- JWT ---
JWT_SECRET_KEY=ganti-dengan-secret-key-acak-yang-panjang

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True

# --- UBCF ---
# Jumlah neighbor terdekat yang dipakai UBCF
UBCF_K_NEIGHBORS=3
# Jumlah rekomendasi yang dikembalikan per user
UBCF_TOP_N=4
